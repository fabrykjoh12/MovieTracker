# Public browser configuration from the Neon Auth and Data API pages.
# These URLs contain no database password, but the Data API must only be enabled
# after every exposed table has appropriate Row Level Security policies.
VITE_NEON_AUTH_URL=https://copy-the-exact-auth-url-from-neon
VITE_NEON_DATA_API_URL=https://copy-the-exact-data-api-url-from-neon

# Public URL of the deployed catalog Worker. The Worker keeps both private
# credentials server-side; this browser value is only its HTTPS endpoint.
VITE_CATALOG_API_URL=https://movie-tracker-catalog.your-subdomain.workers.dev

# Server-only migration and catalog Worker credential. Never prefix this with
# VITE_ or commit it.
DATABASE_URL=postgresql://user:password@your-project.neon.tech/neondb?sslmode=require

# Server/build-only TMDB credential. Create this under TMDB account settings.
# Never prefix it with VITE_; the browser must not receive this token.
TMDB_READ_ACCESS_TOKEN=copy-your-tmdb-api-read-access-token
