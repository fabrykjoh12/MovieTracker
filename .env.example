# Public browser configuration from the Neon Auth and Data API pages.
# These URLs contain no database password, but the Data API must only be enabled
# after every exposed table has appropriate Row Level Security policies.
VITE_NEON_AUTH_URL=https://copy-the-exact-auth-url-from-neon
VITE_NEON_DATA_API_URL=https://copy-the-exact-data-api-url-from-neon

# Server-only migration credential. Never prefix this with VITE_ or commit it.
DATABASE_URL=postgresql://user:password@your-project.neon.tech/neondb?sslmode=require
