{
  "name": "movie-tracker",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "worker:check": "tsc -p tsconfig.worker.json --noEmit && wrangler deploy --config worker/wrangler.jsonc --dry-run --outdir dist-worker",
    "worker:dev": "wrangler dev --config worker/wrangler.jsonc",
    "worker:deploy": "wrangler deploy --config worker/wrangler.jsonc",
    "catalog:sync": "node --env-file-if-exists=.env.local scripts/sync-tmdb-catalog.mjs",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"worker/**/*.{ts,jsonc}\" \"scripts/**/*.{js,mjs}\" \"catalog/**/*.json\" \"*.{json,js,ts,html,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\" \"worker/**/*.{ts,jsonc}\" \"scripts/**/*.{js,mjs}\" \"catalog/**/*.json\" \"*.{json,js,ts,html,md}\"",
    "lint": "eslint .",
    "typecheck": "tsc -b --pretty false && tsc -p tsconfig.worker.json --noEmit --pretty false",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "vite preview",
    "db:migrate": "node --env-file-if-exists=.env.local scripts/migrate.mjs",
    "db:verify": "node --env-file-if-exists=.env.local scripts/verify-database.mjs",
    "db:acceptance": "node --env-file-if-exists=.env.local scripts/verify-production-data.mjs"
  },
  "dependencies": {
    "@neondatabase/neon-js": "^0.6.2-beta",
    "@neondatabase/serverless": "^1.1.0",
    "jose": "^6.2.3",
    "lucide-react": "^0.525.0",
    "pg": "^8.16.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.7.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260717.1",
    "@eslint/js": "^10.0.0",
    "@neondatabase/postgrest-js": "^0.2.0-beta",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.0.0",
    "@types/pg": "^8.15.5",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.0",
    "eslint": "^10.0.0",
    "eslint-plugin-react-hooks": "^7.1.0",
    "eslint-plugin-react-refresh": "^0.5.0",
    "globals": "^16.0.0",
    "jsdom": "^29.0.0",
    "prettier": "^3.6.0",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.0",
    "vitest": "^4.1.0",
    "wrangler": "^4.112.0"
  },
  "overrides": {
    "@better-auth/passkey": "1.6.23",
    "better-auth": "1.6.23"
  }
}
